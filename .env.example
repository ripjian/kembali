# Copy to .env and fill in. NEVER commit real values (ROADMAP §5).

# Postgres connection string (Neon/Supabase in prod, docker-compose locally).
# Used by packages/db for migrations and seeding.
DATABASE_URL=postgres://kembali:kembali@localhost:5432/kembali

# Sentry (optional in dev — apps boot without it; set in prod)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# HMAC secret for customer QR stamp tokens — REQUIRED in production.
# Dev falls back to a fixed non-secret value.
QR_TOKEN_SECRET=