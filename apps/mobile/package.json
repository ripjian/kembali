{
  "name": "@kembali/mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Capacitor shell for branded chain apps (APP.md Stage 2). One codebase, one brand config per chain.",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/check-brands.mjs",
    "sync": "cap sync",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "run:ios": "cap run ios",
    "run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@kembali/config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^10.6.0",
    "typescript": "^5.9.3"
  }
}
