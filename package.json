{
  "name": "kembali",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @kembali/db db:generate",
    "db:migrate": "pnpm --filter @kembali/db db:migrate",
    "db:seed": "pnpm --filter @kembali/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.10.4"
  }
}
